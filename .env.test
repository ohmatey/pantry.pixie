# Test environment overrides
# Ensures tests always use in-memory SQLite regardless of .env DATABASE_URL
NODE_ENV=test

# Unset DATABASE_URL so db.ts NODE_ENV check is not bypassed
DATABASE_URL=

# JWT secret for tests (not a real secret)
JWT_SECRET=test-jwt-secret-at-least-32-characters-long

# Disable OpenAI in tests (mock is used instead)
OPENAI_API_KEY=
