{
  "name": "@pantry-pixie/sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for Pantry Pixie API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ohmatey/pantry.pixie.git",
    "directory": "packages/sdk"
  },
  "keywords": ["pantry", "grocery", "household", "sdk", "typescript", "client"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pantry-pixie/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.2.3",
    "typescript": "^6.0.3"
  }
}
